        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .reviews-section {\n    background: #fff5f8;\n    padding: 32px 16px;\n    width: 100%;\n    box-sizing: border-box;\n    font-family: 'Barlow', Arial, sans-serif;\n    text-align: center;\n  }\n\n  .reviews-stars-row {\n    display: flex;\n    justify-content: center;\n    gap: 8px;\n    margin-bottom: 12px;\n  }\n\n  .reviews-stars {\n    color: #e8a0b4;\n    font-size: 20px;\n  }\n\n  .reviews-title {\n    font-size: 28px;\n    font-weight: 900;\n    color: #111;\n    text-transform: uppercase;\n    margin-bottom: 24px;\n  }\n\n  .reviews-tabs {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 10px;\n    justify-content: center;\n    margin-bottom: 28px;\n  }\n\n  .reviews-tab {\n    padding: 10px 20px;\n    border-radius: 50px;\n    border: 2px solid #ccc;\n    background: #fff;\n    font-size: 14px;\n    font-weight: 700;\n    cursor: pointer;\n  }\n\n  .reviews-tab.active {\n    background: #c0607a;\n    border-color: #c0607a;\n    color: #fff;\n  }\n\n  .reviews-grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 24px;\n    max-width: 1000px;\n    margin: 0 auto;\n  }\n\n  .review-card {\n    text-align: center;\n  }\n\n  .review-card-stars {\n    color: #e8a0b4;\n    font-size: 18px;\n  }\n\n  .review-card-text {\n    font-size: 14px;\n    color: #222;\n  }\n\n  .review-card-author {\n    font-weight: 700;\n    margin-top: 6px;\n  }\n\n  @media (max-width: 599px) {\n    .reviews-grid {\n      grid-template-columns: 1fr;\n    }\n  }\n</style>\n\n<div class=\"reviews-section\">\n\n  <div class=\"reviews-stars-row\">\n    <span class=\"reviews-stars\">★★★★★</span>\n    <span>4.8 stars</span>\n  </div>\n\n  <h2 class=\"reviews-title\">Clear Pores. Real Results.</h2>\n\n  <div class=\"reviews-tabs\">\n    <button class=\"reviews-tab active\" onclick=\"switchTab('results', event)\">Results</button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('effectiveness', event)\">Effectiveness</button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('gentle', event)\">Gentle</button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('ease', event)\">Ease of Use</button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('repurchase', event)\">Would Buy Again</button>\n  </div>\n\n  <div class=\"reviews-grid\" id=\"reviews-grid\"></div>\n\n</div>\n\n<script>\n  const allReviews = {\n    results: [\n      { text: \"I could literally see the blackheads come out. So satisfying!\", author: \"Lara M.\" },\n      { text: \"My nose looks so much cleaner after one use.\", author: \"Nour K.\" },\n      { text: \"This gave me instant results. Skin feels smooth!\", author: \"Maya R.\" },\n    ],\n    effectiveness: [\n      { text: \"Actually works better than anything I've tried before.\", author: \"Rima H.\" },\n      { text: \"Pulled out so much dirt and oil. Amazing.\", author: \"Sara A.\" },\n      { text: \"You can clearly see the difference after using it.\", author: \"Dina F.\" },\n    ],\n    gentle: [\n      { text: \"No irritation at all, very gentle on my skin.\", author: \"Hana S.\" },\n      { text: \"I have sensitive skin and it worked perfectly.\", author: \"Tanya M.\" },\n      { text: \"Didn’t hurt when removing, super comfortable.\", author: \"Celine A.\" },\n    ],\n    ease: [\n      { text: \"Very easy to apply and remove.\", author: \"Nadine T.\" },\n      { text: \"Takes just a few minutes for amazing results.\", author: \"Rana K.\" },\n      { text: \"Perfect for quick skincare routine.\", author: \"Joelle B.\" },\n    ],\n    repurchase: [\n      { text: \"Already ordering again. Love it.\", author: \"Carla N.\" },\n      { text: \"This is now part of my weekly routine.\", author: \"Yasmine F.\" },\n      { text: \"Definitely buying again, no question.\", author: \"Mirna L.\" },\n    ]\n  };\n\n  function switchTab(tab, event) {\n    document.querySelectorAll('.reviews-tab').forEach(btn => btn.classList.remove('active'));\n    event.target.classList.add('active');\n\n    const reviews = allReviews[tab];\n\n    document.getElementById('reviews-grid').innerHTML = reviews.map(r => `\n      <div class=\"review-card\">\n        <div class=\"review-card-stars\">★★★★★</div>\n        <p class=\"review-card-text\">${r.text}</p>\n        <span class=\"review-card-author\">${r.author}</span>\n      </div>\n    `).join('');\n  }\n\n  switchTab('results', { target: document.querySelector('.reviews-tab') });\n</script>",
