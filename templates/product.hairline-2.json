v class=\"reviews-tabs\">\n    <button class=\"reviews-tab active\" onclick=\"switchTab('results', event)\">Results</button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('natural', event)\">Natural Look</button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('ease', event)\">Ease of Use</button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('lasting', event)\">Long Lasting</button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('repurchase', event)\">Would Buy Again</button>\n  </div>\n\n  <div class=\"reviews-grid\" id=\"reviews-grid\"></div>\n\n</div>\n\n<script>\n  const allReviews = {\n    results: [\n      { text: \"This completely changed my hairline. It looks fuller instantly.\", author: \"Lara M.\" },\n      { text: \"My brows look professionally done every day now.\", author: \"Nour K.\" },\n      { text: \"I was shocked how fast it worked. Total confidence boost.\", author: \"Maya R.\" },\n    ],\n    natural: [\n      { text: \"Blends perfectly with my hair. No one can tell I'm using it.\", author: \"Rima H.\" },\n      { text: \"Very natural finish, not powdery or fake.\", author: \"Sara A.\" },\n      { text: \"Looks like real hair, not makeup.\", author: \"Dina F.\" },\n    ],\n    ease: [\n      { text: \"Super easy to apply. Takes 10 seconds.\", author: \"Hana S.\" },\n      { text: \"Mess-free and beginner friendly.\", author: \"Tanya M.\" },\n      { text: \"Perfect for quick touch-ups before going out.\", author: \"Celine A.\" },\n    ],\n    lasting: [\n      { text: \"Lasts all day even in heat.\", author: \"Nadine T.\" },\n      { text: \"Didn’t fade or smudge at all.\", author: \"Rana K.\" },\n      { text: \"Stayed perfect until I washed it off.\", author: \"Joelle B.\" },\n    ],\n    repurchase: [\n      { text: \"Already ordering my second one.\", author: \"Carla N.\" },\n      { text: \"I can't go without this anymore.\", author: \"Yasmine F.\" },\n      { text: \"Definitely a staple in my routine now.\", author: \"Mirna L.\" },\n    ]\n  };\n\n  function switchTab(tab, event) {\n    document.querySelectorAll('.reviews-tab').forEach(btn => btn.classList.remove('active'));\n    event.target.classList.add('active');\n\n    const reviews = allReviews[tab];\n\n    document.getElementById('reviews-grid').innerHTML = reviews.map(r => `\n      <div class=\"review-card\">\n        <div class=\"review-card-stars\">★★★★★</div>\n        <p class=\"review-card-text\">${r.text}</p>\n        <span class=\"review-card-author\">${r.author}</span>\n      </div>\n    `).join('');\n  }\n\n  switchTab('results', { target: document.querySelector('.reviews-tab') });\n</script>",
