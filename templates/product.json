    "custom_liquid_NrUwN9": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.custom_liquid.presets.custom_liquid.name",
      "settings": {
        "color_scheme": "",
        "separate_section_with_border": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .faq-section {\n    background: #fff;\n    padding: 48px 16px;\n    width: 100%;\n    box-sizing: border-box;\n    font-family: 'Barlow', Arial, sans-serif;\n  }\n\n  .faq-inner {\n    max-width: 720px;\n    margin: 0 auto;\n  }\n\n  .faq-title {\n    font-size: 28px;\n    font-weight: 900;\n    color: #111;\n    text-transform: uppercase;\n    margin: 0 0 8px;\n    letter-spacing: 0.02em;\n    text-align: center;\n  }\n\n  .faq-subtitle {\n    font-size: 15px;\n    color: #666;\n    text-align: center;\n    margin: 0 0 36px;\n    font-weight: 400;\n  }\n\n  .faq-item {\n    border-bottom: 1px solid #f0e0e5;\n    overflow: hidden;\n  }\n\n  .faq-item:first-of-type {\n    border-top: 1px solid #f0e0e5;\n  }\n\n  .faq-question {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 18px 4px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n    cursor: pointer;\n    font-family: 'Barlow', Arial, sans-serif;\n    font-size: 15px;\n    font-weight: 700;\n    color: #111;\n    text-align: left;\n    transition: color 0.2s ease;\n  }\n\n  .faq-question:hover {\n    color: #c0607a;\n  }\n\n  .faq-question.open {\n    color: #c0607a;\n  }\n\n  .faq-icon {\n    flex-shrink: 0;\n    width: 28px;\n    height: 28px;\n    border-radius: 50%;\n    background: #fff5f8;\n    border: 2px solid #f0ccd6;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 18px;\n    font-weight: 400;\n    color: #c0607a;\n    transition: background 0.2s ease, transform 0.3s ease;\n    line-height: 1;\n  }\n\n  .faq-question.open .faq-icon {\n    background: #c0607a;\n    color: #fff;\n    transform: rotate(45deg);\n  }\n\n  .faq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.35s ease, padding 0.3s ease;\n    padding: 0 4px;\n  }\n\n  .faq-answer.open {\n    max-height: 300px;\n    padding: 0 4px 18px;\n  }\n\n  .faq-answer p {\n    margin: 0;\n    font-size: 14px;\n    font-weight: 400;\n    color: #555;\n    line-height: 1.75;\n  }\n\n  @media (max-width: 599px) {\n    .faq-title {\n      font-size: 20px;\n    }\n    .faq-question {\n      font-size: 14px;\n    }\n  }\n</style>\n\n<div class=\"faq-section\">\n  <div class=\"faq-inner\">\n\n    <h2 class=\"faq-title\">Frequently Asked Questions</h2>\n    <p class=\"faq-subtitle\">Everything you need to know before you glow ✨</p>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        Do you deliver all over Lebanon?\n        <span class=\"faq-icon\">+</span>\n      </button>\n      <div class=\"faq-answer\">\n        <p>Yes! We deliver to all regions across Lebanon — Beirut, Mount Lebanon, North, South, Bekaa, and everywhere in between. Delivery typically takes 1–3 business days depending on your location.</p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        Do you offer cash on delivery?\n        <span class=\"faq-icon\">+</span>\n      </button>\n      <div class=\"faq-answer\">\n        <p>Absolutely. We offer cash on delivery (COD) on all orders. No credit card, no online payment required — just pay when your order arrives at your door.</p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        Are your products safe to use?\n        <span class=\"faq-icon\">+</span>\n      </button>\n      <div class=\"faq-answer\">\n        <p>Yes. Every product we carry is carefully selected for quality and safety. We only stock products that are tested, trusted, and used by real customers — your skin and confidence matter to us.</p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        Can I return a product if I'm not happy?\n        <span class=\"faq-icon\">+</span>\n      </button>\n      <div class=\"faq-answer\">\n        <p>Customer satisfaction is our priority. If you're not happy with your purchase, contact us within 48 hours of receiving your order and we'll do our best to make it right — whether that's a replacement or a solution that works for you.</p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" onclick=\"toggleFaq(this)\">\n        What if I don't know which product is right for me?\n        <span class=\"faq-icon\">+</span>\n      </button>\n      <div class=\"faq-answer\">\n        <p>We're here to help! Reach out to us via the Contact page or DM us on Instagram and we'll recommend the best products based on your needs and skin type. We love helping you find your perfect match.</p>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n  function toggleFaq(btn) {\n    const answer = btn.nextElementSibling;\n    const isOpen = btn.classList.contains('open');\n\n    document.querySelectorAll('.faq-question').forEach(q => q.classList.remove('open'));\n    document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));\n\n    if (!isOpen) {\n      btn.classList.add('open');\n      answer.classList.add('open');\n    }\n  }\n</script>",
        "text_alignment": "center"
      }
    },
