        "remove_horizontal_spacing": false,
        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .compare-section {\n    background: #fff5f8;\n    padding: 48px 16px;\n    width: 100%;\n    box-sizing: border-box;\n    font-family: 'Barlow', Arial, sans-serif;\n    text-align: center;\n  }\n\n  .compare-title {\n    font-size: 28px;\n    font-weight: 900;\n    color: #111;\n    text-transform: uppercase;\n    margin: 0 0 8px;\n    letter-spacing: 0.02em;\n  }\n\n  .compare-subtitle {\n    font-size: 15px;\n    color: #666;\n    margin: 0 0 32px;\n    font-weight: 400;\n  }\n\n  .compare-wrapper {\n    max-width: 780px;\n    margin: 0 auto;\n    border-radius: 16px;\n    overflow: hidden;\n    box-shadow: 0 4px 32px rgba(192, 96, 122, 0.12);\n  }\n\n  /* HEADER ROW */\n  .compare-header {\n    display: grid;\n    grid-template-columns: 2fr 1fr 1fr;\n    background: #111;\n  }\n\n  .compare-header-cell {\n    padding: 16px 12px;\n    font-size: 13px;\n    font-weight: 800;\n    text-transform: uppercase;\n    letter-spacing: 0.08em;\n    color: #aaa;\n  }\n\n  .compare-header-cell.us {\n    background: #ff65c3;\n    color: #fff;\n    font-size: 15px;\n    letter-spacing: 0.04em;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    gap: 4px;\n  }\n\n  .compare-header-cell.us .brand-name {\n    font-size: 17px;\n    font-weight: 900;\n    color: #fff;\n    letter-spacing: 0.02em;\n  }\n\n  .compare-header-cell.them {\n    color: #666;\n  }\n\n  /* ROWS */\n  .compare-row {\n    display: grid;\n    grid-template-columns: 2fr 1fr 1fr;\n    border-top: 1px solid #f0e0e5;\n    background: #fff;\n    transition: background 0.15s ease;\n  }\n\n  .compare-row:hover {\n    background: #fff8fa;\n  }\n\n  .compare-row:last-child {\n    border-bottom-left-radius: 16px;\n    border-bottom-right-radius: 16px;\n    overflow: hidden;\n  }\n\n  .compare-cell {\n    padding: 16px 14px;\n    font-size: 14px;\n    font-weight: 500;\n    color: #333;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    text-align: center;\n    border-left: 1px solid #f0e0e5;\n  }\n\n  .compare-cell:first-child {\n    justify-content: flex-start;\n    text-align: left;\n    border-left: none;\n    font-weight: 600;\n    color: #111;\n    font-size: 14px;\n  }\n\n  .compare-cell.us-col {\n    background: #fff5f8;\n    font-weight: 700;\n  }\n\n  /* CHECK / CROSS */\n  .check {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 28px;\n    height: 28px;\n    border-radius: 50%;\n    background: #ff65c3;\n    color: #fff;\n    font-size: 15px;\n    font-weight: 900;\n    flex-shrink: 0;\n  }\n\n  .cross {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 28px;\n    height: 28px;\n    border-radius: 50%;\n    background: #eee;\n    color: #aaa;\n    font-size: 15px;\n    font-weight: 900;\n    flex-shrink: 0;\n  }\n\n  /* CTA */\n  .compare-cta {\n    margin-top: 28px;\n    display: flex;\n    justify-content: center;\n  }\n\n  .compare-cta a {\n    background: #c0607a;\n    color: #fff;\n    font-family: 'Barlow', Arial, sans-serif;\n    font-size: 15px;\n    font-weight: 800;\n    text-transform: uppercase;\n    letter-spacing: 0.06em;\n    padding: 14px 36px;\n    border-radius: 50px;\n    text-decoration: none;\n    transition: background 0.2s ease, transform 0.15s ease;\n    display: inline-block;\n  }\n\n  .compare-cta a:hover {\n    background: #a84e67;\n    transform: translateY(-2px);\n  }\n\n  @media (max-width: 599px) {\n    .compare-title {\n      font-size: 20px;\n    }\n    .compare-cell,\n    .compare-header-cell {\n      padding: 12px 8px;\n      font-size: 12px;\n    }\n    .compare-cell:first-child {\n      font-size: 12px;\n    }\n    .check, .cross {\n      width: 22px;\n      height: 22px;\n      font-size: 12px;\n    }\n    .compare-header-cell.us .brand-name {\n      font-size: 13px;\n    }\n  }\n</style>\n\n<div class=\"compare-section\">\n\n  <h2 class=\"compare-title\">Why Choose The More You Glow?</h2>\n  <p class=\"compare-subtitle\">See how we stack up against regular beauty stores</p>\n\n  <div class=\"compare-wrapper\">\n\n    <!-- HEADER -->\n    <div class=\"compare-header\">\n      <div class=\"compare-header-cell\">Features</div>\n      <div class=\"compare-header-cell us\">\n        <span class=\"brand-name\">✦ Us</span>\n        <span></span>\n      </div>\n      <div class=\"compare-header-cell them\">Other Stores</div>\n    </div>\n\n    <!-- ROWS -->\n    <div class=\"compare-row\">\n      <div class=\"compare-cell\">Delivery All Over Lebanon</div>\n      <div class=\"compare-cell us-col\"><span class=\"check\">✓</span></div>\n      <div class=\"compare-cell\"><span class=\"cross\">✗</span></div>\n    </div>\n\n    <div class=\"compare-row\">\n      <div class=\"compare-cell\">Cash on Delivery</div>\n      <div class=\"compare-cell us-col\"><span class=\"check\">✓</span></div>\n      <div class=\"compare-cell\"><span class=\"cross\">✗</span></div>\n    </div>\n\n    <div class=\"compare-row\">\n      <div class=\"compare-cell\">Carefully Curated Products</div>\n      <div class=\"compare-cell us-col\"><span class=\"check\">✓</span></div>\n      <div class=\"compare-cell\"><span class=\"cross\">✗</span></div>\n    </div>\n\n    <div class=\"compare-row\">\n      <div class=\"compare-cell\">Real Customer Reviews</div>\n      <div class=\"compare-cell us-col\"><span class=\"check\">✓</span></div>\n      <div class=\"compare-cell\"><span class=\"cross\">✗</span></div>\n    </div>\n\n    <div class=\"compare-row\">\n      <div class=\"compare-cell\">Fast 1–3 Day Shipping</div>\n      <div class=\"compare-cell us-col\"><span class=\"check\">✓</span></div>\n      <div class=\"compare-cell\"><span class=\"cross\">✗</span></div>\n    </div>\n\n    <div class=\"compare-row\">\n      <div class=\"compare-cell\">Affordable Prices</div>\n      <div class=\"compare-cell us-col\"><span class=\"check\">✓</span></div>\n      <div class=\"compare-cell\"><span class=\"cross\">✗</span></div>\n    </div>\n\n    <div class=\"compare-row\">\n      <div class=\"compare-cell\">Dedicated Customer Support</div>\n      <div class=\"compare-cell us-col\"><span class=\"check\">✓</span></div>\n      <div class=\"compare-cell\"><span class=\"cross\">✗</span></div>\n    </div>\n\n    <div class=\"compare-row\">\n      <div class=\"compare-cell\">Safe & Tested Beauty Products</div>\n      <div class=\"compare-cell us-col\"><span class=\"check\">✓</span></div>\n      <div class=\"compare-cell\"><span class=\"cross\">✗</span></div>\n    </div>\n\n  </div>\n\n\n</div>",
