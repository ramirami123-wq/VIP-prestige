        "separate_section_with_border": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "<style>\n.glow-table {\n  width: 100%;\n  border-collapse: collapse;\n  text-align: center;\n  margin: 25px 0;\n  font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\n  border: 1px solid #e0e0e0;\n}\n.glow-table th, \n.glow-table td {\n  padding: 16px 12px;\n  border: 1px solid #e0e0e0;\n  font-size: 15px;\n}\n.glow-table th {\n  background: #f5f5f5;\n  font-weight: 500;\n  color: #555;\n}\n.glow-table .our-header {\n  background: #4a4a4a;\n  color: #ffffff;\n  font-weight: 600;\n}\n.glow-table .our-col {\n  background: #000000;\n  color: #ffffff;\n}\n.glow-table .check {\n  color: #00c853;\n  font-size: 22px;\n  font-weight: bold;\n}\n.glow-table .xmark {\n  color: #ff1744;\n  font-size: 22px;\n  font-weight: bold;\n}\n.glow-table td {\n  background: #ffffff;\n  color: #333;\n}\n</style>\n\n<h2 style=\"text-align:center; font-size:24px; font-weight:500; margin-bottom:25px; letter-spacing:0.5px;\">Why Our Tattoo Brow Pen Wins</h2>\n\n<table class=\"glow-table\">\n  <tr>\n    <th>Feature</th>\n    <th class=\"our-header\">Our Tattoo Brow</th>\n    <th>Other Brands</th>\n  </tr>\n  <tr>\n    <td>Lasts Up To 24 Hours</td>\n    <td class=\"our-col\"><span class=\"check\">✓</span></td>\n    <td><span class=\"xmark\">✗</span></td>\n  </tr>\n  <tr>\n    <td>Waterproof Formula</td>\n    <td class=\"our-col\"><span class=\"check\">✓</span></td>\n    <td><span class=\"xmark\">✗</span></td>\n  </tr>\n  <tr>\n    <td>Smudge-Resistant</td>\n    <td class=\"our-col\"><span class=\"check\">✓</span></td>\n    <td><span class=\"xmark\">✗</span></td>\n  </tr>\n  <tr>\n    <td>Natural Hair-Stroke Look</td>\n    <td class=\"our-col\"><span class=\"check\">✓</span></td>\n    <td><span class=\"xmark\">✗</span></td>\n  </tr>\n  <tr>\n    <td>Easy &amp; Fast Application</td>\n    <td class=\"our-col\"><span class=\"check\">✓</span></td>\n    <td><span class=\"xmark\">✗</span></td>\n  </tr>\n</table>",
        "text_alignment": "center"
      }
