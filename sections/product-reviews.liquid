    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Results. Real People."
    },
    {
      "type": "checkbox",
      "id": "show_aggregate",
      "label": "Show average rating",
      "default": true
    },
    {
      "type": "header",
