{% comment %}
  ============================================================
  HERO BANNER — The More You Glow
  Section: hero-banner.liquid
  Drop into: sections/hero-banner.liquid
  Add to template via Customizer → Add section → Hero Banner
  ============================================================
{% endcomment %}

{%- assign bg_image = section.settings.background_image -%}
{%- assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0 -%}

<section
  id="hero-banner-{{ section.id }}"
  class="tmyg-hero"
  style="
    --hero-min-height: {{ section.settings.section_height }}px;
    --hero-overlay: {{ overlay_opacity }};
    --hero-text-align: {{ section.settings.text_alignment }};
    --hero-content-align: {% if section.settings.text_alignment == 'left' %}flex-start{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}center{% endif %};
  "
  aria-label="{{ section.settings.heading | escape }}"
>

  {%- comment %} ── Background ── {%- endcomment %}
  <div class="tmyg-hero__bg">
    {%- if bg_image != blank -%}
      <img
        src="{{ bg_image | image_url: width: 2400 }}"
        srcset="
          {{ bg_image | image_url: width: 768 }} 768w,
          {{ bg_image | image_url: width: 1200 }} 1200w,
          {{ bg_image | image_url: width: 1800 }} 1800w,
          {{ bg_image | image_url: width: 2400 }} 2400w
        "
        sizes="100vw"
        alt="{{ bg_image.alt | default: section.settings.heading | escape }}"
        loading="eager"
        fetchpriority="high"
        width="{{ bg_image.width }}"
        height="{{ bg_image.height }}"
        class="tmyg-hero__img"
      >
    {%- else -%}
      <div class="tmyg-hero__img tmyg-hero__img--placeholder"></div>
    {%- endif -%}
    <div class="tmyg-hero__overlay"></div>
  </div>

  {%- comment %} ── Floating Badge (optional sale pill) ── {%- endcomment %}
  {%- if section.settings.badge_text != blank -%}
    <div class="tmyg-hero__badge" aria-hidden="true">
      <span>{{ section.settings.badge_text }}</span>
    </div>
  {%- endif -%}

  {%- comment %} ── Content ── {%- endcomment %}
  <div class="tmyg-hero__content-wrap">
    <div class="tmyg-hero__content">

      {%- if section.settings.eyebrow != blank -%}
        <p class="tmyg-hero__eyebrow animate-in animate-in--0">
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="tmyg-hero__heading animate-in animate-in--1">
          {{ section.settings.heading }}
        </h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="tmyg-hero__subheading animate-in animate-in--2">
          {{ section.settings.subheading }}
        </p>
      {%- endif -%}

      {%- comment %} ── Trust pills ── {%- endcomment %}
      <div class="tmyg-hero__pills animate-in animate-in--3">
        {%- if section.settings.pill_1 != blank -%}
          <span class="tmyg-hero__pill">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="6.5" stroke="currentColor" stroke-opacity=".6"/>
              <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ section.settings.pill_1 }}
          </span>
        {%- endif -%}
        {%- if section.settings.pill_2 != blank -%}
          <span class="tmyg-hero__pill">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="6.5" stroke="currentColor" stroke-opacity=".6"/>
              <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ section.settings.pill_2 }}
          </span>
        {%- endif -%}
        {%- if section.settings.pill_3 != blank -%}
          <span class="tmyg-hero__pill">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <circle cx="7" cy="7" r="6.5" stroke="currentColor" stroke-opacity=".6"/>
              <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ section.settings.pill_3 }}
          </span>
        {%- endif -%}
      </div>

      {%- comment %} ── CTA Buttons ── {%- endcomment %}
      <div class="tmyg-hero__actions animate-in animate-in--4">
        {%- if section.settings.cta_primary_label != blank -%}
          <a
            href="{{ section.settings.cta_primary_url | default: '/collections/all' }}"
            class="tmyg-btn tmyg-btn--primary"
          >
            {{ section.settings.cta_primary_label }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.cta_secondary_label != blank -%}
          <a
            href="{{ section.settings.cta_secondary_url | default: '/pages/contact' }}"
            class="tmyg-btn tmyg-btn--ghost"
          >
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>

  {%- comment %} ── Scroll indicator ── {%- endcomment %}
  {%- if section.settings.show_scroll_indicator -%}
    <div class="tmyg-hero__scroll" aria-hidden="true">
      <span></span>
    </div>
  {%- endif -%}

</section>

{%- comment %} ════ Styles ════ {%- endcomment %}
<style>
  #hero-banner-{{ section.id }} {
    --hero-accent:    {{ section.settings.accent_color }};
    --hero-text:      {{ section.settings.text_color }};
    --hero-btn-bg:    {{ section.settings.btn_bg_color }};
    --hero-btn-text:  {{ section.settings.btn_text_color }};
  }

  .tmyg-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: var(--hero-content-align);
    min-height: var(--hero-min-height, 92vh);
    overflow: hidden;
    color: var(--hero-text, #fff);
    text-align: var(--hero-text-align, center);
  }

  /* ── Background ── */
  .tmyg-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .tmyg-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .tmyg-hero__img--placeholder {
    background: linear-gradient(135deg, #f7c5d7 0%, #fde9f0 50%, #f4a7c3 100%);
  }
  .tmyg-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(0, 0, 0, calc(var(--hero-overlay) * 0.6)) 0%,
      rgba(0, 0, 0, calc(var(--hero-overlay) * 0.9)) 60%,
      rgba(0, 0, 0, calc(var(--hero-overlay) * 1.0)) 100%
    );
  }

  /* ── Badge ── */
  .tmyg-hero__badge {
    position: absolute;
    top: 2rem;
    right: 2rem;
    z-index: 10;
    animation: hero-badge-in .6s cubic-bezier(.22,1,.36,1) .4s both;
  }
  .tmyg-hero__badge span {
    display: inline-block;
    background: var(--hero-accent, #D4537E);
    color: #fff;
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: .45rem 1rem;
    border-radius: 2rem;
  }
  @keyframes hero-badge-in {
    from { opacity: 0; transform: translateY(-12px) scale(.9); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ── Content wrap ── */
  .tmyg-hero__content-wrap {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 6rem 2rem;
  }
  .tmyg-hero__content {
    max-width: 680px;
    margin: {% if section.settings.text_alignment == 'center' %}0 auto{% elsif section.settings.text_alignment == 'right' %}0 0 0 auto{% else %}0{% endif %};
  }

  /* ── Eyebrow ── */
  .tmyg-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--hero-accent, #F4C0D1);
    margin-bottom: 1.25rem;
  }
  .tmyg-hero__eyebrow::before,
  .tmyg-hero__eyebrow::after {
    content: '';
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--hero-accent, #F4C0D1);
    opacity: .7;
  }

  /* ── Heading ── */
  .tmyg-hero__heading {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -.02em;
    color: var(--hero-text, #fff);
    margin-bottom: 1.25rem;
    text-wrap: balance;
  }

  /* ── Sub-heading ── */
  .tmyg-hero__subheading {
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    line-height: 1.6;
    color: var(--hero-text, #fff);
    opacity: .85;
    margin-bottom: 1.75rem;
    max-width: 520px;
    margin-left: {% if section.settings.text_alignment == 'center' %}auto{% else %}0{% endif %};
    margin-right: {% if section.settings.text_alignment == 'center' %}auto{% elsif section.settings.text_alignment == 'right' %}0{% else %}0{% endif %};
  }

  /* ── Trust pills ── */
  .tmyg-hero__pills {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-bottom: 2rem;
    justify-content: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
  }
  .tmyg-hero__pill {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-size: .78rem;
    font-weight: 500;
    color: var(--hero-text, #fff);
    background: rgba(255, 255, 255, .12);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, .2);
    padding: .35rem .85rem;
    border-radius: 2rem;
    white-space: nowrap;
  }

  /* ── Buttons ── */
  .tmyg-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: {% if section.settings.text_alignment == 'center' %}center{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
  }
  .tmyg-btn {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: .95rem;
    font-weight: 600;
    letter-spacing: .01em;
    padding: .9rem 2rem;
    border-radius: .35rem;
    text-decoration: none;
    transition: transform .2s ease, box-shadow .2s ease, background .2s ease;
    cursor: pointer;
  }
  .tmyg-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,.3);
  }
  .tmyg-btn:active { transform: translateY(0); }

  .tmyg-btn--primary {
    background: var(--hero-btn-bg, #D4537E);
    color: var(--hero-btn-text, #fff);
    border: 2px solid transparent;
  }
  .tmyg-btn--primary:hover {
    background: var(--hero-accent, #b83d66);
  }
  .tmyg-btn--ghost {
    background: transparent;
    color: var(--hero-text, #fff);
    border: 2px solid rgba(255,255,255,.5);
  }
  .tmyg-btn--ghost:hover {
    background: rgba(255,255,255,.1);
    border-color: rgba(255,255,255,.8);
  }

  /* ── Scroll indicator ── */
  .tmyg-hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
  }
  .tmyg-hero__scroll span {
    display: block;
    width: 24px;
    height: 38px;
    border: 2px solid rgba(255,255,255,.5);
    border-radius: 12px;
    position: relative;
  }
  .tmyg-hero__scroll span::after {
    content: '';
    display: block;
    width: 4px;
    height: 8px;
    background: rgba(255,255,255,.8);
    border-radius: 2px;
    position: absolute;
    top: 5px;
    left: 50%;
    transform: translateX(-50%);
    animation: tmyg-scroll 1.8s ease-in-out infinite;
  }
  @keyframes tmyg-scroll {
    0%   { opacity: 1; transform: translateX(-50%) translateY(0); }
    80%  { opacity: 0; transform: translateX(-50%) translateY(14px); }
    100% { opacity: 0; transform: translateX(-50%) translateY(0); }
  }

  /* ── Entrance animations ── */
  .animate-in {
    opacity: 0;
    transform: translateY(24px);
    animation: tmyg-fade-up .7s cubic-bezier(.22,1,.36,1) forwards;
  }
  .animate-in--0 { animation-delay: .15s; }
  .animate-in--1 { animation-delay: .28s; }
  .animate-in--2 { animation-delay: .4s; }
  .animate-in--3 { animation-delay: .52s; }
  .animate-in--4 { animation-delay: .64s; }
  @keyframes tmyg-fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Responsive ── */
  @media (max-width: 767px) {
    .tmyg-hero__content-wrap { padding: 5rem 1.25rem 4rem; }
    .tmyg-hero__badge { top: 1rem; right: 1rem; }
    .tmyg-hero { min-height: 90svh; text-align: center !important; }
    .tmyg-hero__pills,
    .tmyg-hero__actions { justify-content: center !important; }
    .tmyg-hero__subheading { margin-left: auto !important; margin-right: auto !important; }
    .tmyg-btn { padding: .8rem 1.5rem; font-size: .9rem; }
    .tmyg-hero__eyebrow::before,
    .tmyg-hero__eyebrow::after { width: 1.25rem; }
  }
</style>

{%- comment %} ════ Schema ════ {%- endcomment %}
{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Recommended: 2400 × 1350px or larger"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay darkness",
      "default": 45
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Minimum section height",
      "default": 720
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Sale badge (optional)",
      "default": "🌸 Spring Sale — Up to 30% off"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Premium Beauty · Lebanon"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main headline",
      "default": "Let Your Beauty\nGlow Louder"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sub-headline",
      "default": "Carefully curated beauty products that deliver real results. Fast delivery all over Lebanon — Cash on Delivery available."
    },
    {
      "type": "header",
      "content": "Trust pills"
    },
    {
      "type": "text",
      "id": "pill_1",
      "label": "Trust pill 1",
      "default": "Cash on Delivery"
    },
    {
      "type": "text",
      "id": "pill_2",
      "label": "Trust pill 2",
      "default": "Nationwide Delivery"
    },
    {
      "type": "text",
      "id": "pill_3",
      "label": "Trust pill 3",
      "default": "Premium Quality"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary button label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "header",
      "content": "Layout & Style"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#D4537E"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Primary button background",
      "default": "#D4537E"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Primary button text",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}
